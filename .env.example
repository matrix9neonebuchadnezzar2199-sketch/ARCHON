# ===========================================
# ARCHON — API keys & system settings
# Copy to .env and fill in values
# ===========================================

# --- LLM providers (at least one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# --- Financial data ---
FINANCIAL_DATASETS_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- LLM defaults ---
LLM_PROVIDER=openai
DEEP_THINK_MODEL=gpt-4.1
QUICK_THINK_MODEL=gpt-4.1-mini
GURU_MODEL=gpt-4.1
OUTPUT_LANGUAGE=Japanese

# --- Provider-specific thinking ---
# ANTHROPIC_EFFORT=            # high | medium | low
# OPENAI_REASONING_EFFORT=     # high | medium | low
# GOOGLE_THINKING_LEVEL=       # high | minimal

# --- ARCHON directories (optional; defaults under project root) ---
# ARCHON_CACHE_DIR=
# ARCHON_RESULTS_DIR=
# ARCHON_MEMORY_DIR=

# --- Docker / ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3501
